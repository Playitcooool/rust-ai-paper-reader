{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Paper Reader",
  "version": "0.1.0",
  "identifier": "com.codex.paper-reader",
  "build": {
    "beforeDevCommand": "npm run dev:tauri",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Paper Reader",
        "width": 1560,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": ["resources/tessdata/*"]
  }
}
